{
  "name": "hodlhunt-manager",
  "version": "1.0.0",
  "description": "HodlHunt Manager - Ocean Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node obfuscate.js && electron-builder --win --x64 && node obfuscate.js --restore",
    "start:silent": "electron . --no-sandbox 2>nul",
    "build:noobf": "electron-builder --win --x64 --config.directories.app=.",
    "build:portable": "node obfuscate.js && electron-builder --win portable --x64 && node obfuscate.js --restore",
    "build:portable:fast": "electron-builder --win portable --x64 --config.directories.app=."
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.3",
    "bs58": "^4.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "javascript-obfuscator": "^4.1.1"
  },
  "build": {
    "appId": "com.hodlhunt.manager",
    "productName": "HodlHunt Manager",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "renderer/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "executableName": "HodlHunt Manager"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!dist-obf/**",
      "!obfuscate.js",
      "!reset-license.js",
      "!start-silent.vbs",
      "!create-shortcut.bat",
      "!README.md"
    ],
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HodlHunt Manager",
      "installerIcon": "renderer/icon.ico",
      "uninstallerIcon": "renderer/icon.ico",
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true
    },
    "extraMetadata": {
      "main": "main.js"
    },
    "directories": {
      "app": "dist-obf"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": "../.env"
      }
    ]
  },
  "productName": "HodlHunt Manager"
}